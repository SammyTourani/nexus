# Required: Anthropic API key for planning (Claude Sonnet 4.6) and verification (Claude Haiku 4.5)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Optional: Vision model name (default: qwen3-vl:8b)
OLLAMA_VISION_MODEL=qwen3-vl:8b

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
NEXUS_LOG_LEVEL=INFO

# Optional: Max retries per action step before giving up
NEXUS_MAX_RETRIES=3
